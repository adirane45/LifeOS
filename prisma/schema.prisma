generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
 
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum HabitFrequency {
  DAILY
  WEEKLY
}

enum HealthMetricType {
  WEIGHT
  SLEEP
  HEART_RATE
  STEPS
  MOOD
  WATER_INTAKE
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  preferences    Json?
  accounts       Account[]
  contacts       Contact[]
  budgets        Budget[]
  bills          Bill[]
  habits         Habit[]
  healthMetrics  HealthMetric[]
  journalEntries JournalEntry[]
  goals          Goal[]
  splitGroups    SplitGroup[]
  investments    Investment[]
  assistantMessages AssistantMessage[]
  suggestions     Suggestion[]
}

model Account {
  id           Int            @id @default(autoincrement())
  userId       Int
  name         String
  type         AccountType
  currency     String
  balance      Float          @default(0)
  user         User           @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id          Int             @id @default(autoincrement())
  accountId   Int
  amount      Float
  category    String
  description String?
  date        DateTime
  isRecurring Boolean         @default(false)
  recurrenceRule String?
  recurrenceEndDate DateTime?
  parentTransactionId Int?
  type        TransactionType
  account     Account         @relation(fields: [accountId], references: [id])
}

model Budget {
  id       Int      @id @default(autoincrement())
  userId   Int
  category String
  amount   Float
  month    DateTime
  user     User     @relation(fields: [userId], references: [id])
}

model Bill {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  amount    Float
  dueDate   DateTime
  frequency String
  category  String
  isPaid    Boolean  @default(false)
  paidDate  DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isPaid, dueDate])
}

model Habit {
  id          Int           @id @default(autoincrement())
  userId      Int
  name        String
  frequency   HabitFrequency
  targetCount Int
  user        User          @relation(fields: [userId], references: [id])
  logs        HabitLog[]
}

model HabitLog {
  id        Int      @id @default(autoincrement())
  habitId   Int
  date      DateTime
  completed Boolean
  count     Int      @default(1)
  habit     Habit    @relation(fields: [habitId], references: [id])

  @@unique([habitId, date])
}

model HealthMetric {
  id     Int               @id @default(autoincrement())
  userId Int
  type   HealthMetricType
  value  Float
  unit   String?
  date   DateTime
  user   User              @relation(fields: [userId], references: [id])
}

model JournalEntry {
  id      Int      @id @default(autoincrement())
  userId  Int
  title   String
  content String
  mood    String?
  date    DateTime
  user    User     @relation(fields: [userId], references: [id])
}

model Goal {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  targetDate  DateTime?
  completed   Boolean  @default(false)
  category    String
  targetValue Float?
  currentValue Float?
  unit        String?
  user        User     @relation(fields: [userId], references: [id])
}

model SplitGroup {
  id          Int          @id @default(autoincrement())
  userId      Int
  name        String
  totalAmount Float        @default(0)
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id])
  shares      SplitShare[]

  @@index([userId])
}

model SplitShare {
  id           Int        @id @default(autoincrement())
  splitGroupId Int
  personName   String
  amount       Float
  settled      Boolean    @default(false)
  group        SplitGroup @relation(fields: [splitGroupId], references: [id], onDelete: Cascade)

  @@index([splitGroupId])
}

model Investment {
  id           Int                      @id @default(autoincrement())
  userId       Int
  name         String
  symbol       String
  type         String                   // "STOCK", "MUTUAL_FUND", "CRYPTO", "ETF", "BOND", "REAL_ESTATE", "OTHER"
  quantity     Float
  buyPrice     Float
  currency     String                   @default("USD")
  accountId    Int?
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  user         User                     @relation(fields: [userId], references: [id])
  transactions InvestmentTransaction[]

  @@index([userId])
}

model InvestmentTransaction {
  id           Int        @id @default(autoincrement())
  investmentId Int
  type         String     // "BUY", "SELL", "DIVIDEND"
  quantity     Float
  price        Float
  date         DateTime
  notes        String?
  investment   Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId])
}

model Contact {
  id               Int      @id @default(autoincrement())
  userId           Int
  name             String
  relationship     String?
  birthday         DateTime?
  phone            String?
  email            String?
  notes            String?
  importantDates   Json?
  lastContacted    DateTime?
  remindAfterDays  Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, name])
}

model AssistantMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Suggestion {
  id          Int      @id @default(autoincrement())
  userId      Int
  text        String
  icon        String
  actionLabel String?
  actionUrl   String?
  date        DateTime @default(now())
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
